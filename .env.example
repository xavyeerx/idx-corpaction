# Telegram
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890
# Chat/user terpisah untuk notifikasi kesehatan sistem (boleh sama dengan TELEGRAM_CHAT_ID)
TELEGRAM_ADMIN_CHAT_ID=-1001234567890

# Polling ke endpoint https://www.idx.co.id/primary/ListedCompany/GetAnnouncement (PRD bagian 3)
# Jumlah hasil per request per kategori keyword
POLL_PAGE_SIZE=20
# Interval antar-mulainya siklus polling (satu siklus = N request berurutan, satu per kategori)
POLL_INTERVAL_SECONDS=30
POLL_BACKOFF_MAX_SECONDS=600
POLL_MAX_CONSECUTIVE_FAILURES=10

# Jam bursa (WIB)
MARKET_OPEN_TIME=08:45
MARKET_CLOSE_TIME=16:15
PRE_OPEN_CHECK_TIME=08:30

# Database
SQLITE_DB_PATH=data/seen_announcements.sqlite3

# Logging
LOG_FILE_PATH=logs/idx_alert.log
LOG_LEVEL=INFO
